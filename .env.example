# ─────────────────────────────────────────────────────────────
#  Air Quality Monitor — Environment Variables Template
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── WAQI API (required) ───────────────────────────────────────
# Get your free token at: https://aqicn.org/data-platform/token/
WAQI_API_TOKEN=your_waqi_api_token_here

# ── OpenAI Guidance Bot (required for AI chat) ────────────────
# Set your OpenAI API key here to enable the chat-style guidance bot.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5.2
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_SEC=30

# ── Device Location (optional, used for startup auto-detect) ──
IPINFO_TOKEN=your_ipinfo_token_here
LOCATION_API_TOKEN=your_ipinfo_token_here
IPINFO_BASE_URL=https://ipinfo.io

# ── Live Background Images (optional) ────────────────────────
# Pexels is preferred when available.
# Get a key at https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_api_key_here
# Optional legacy fallback:
GETTY_API_KEY=your_getty_api_key_here

# ── Flask Server ─────────────────────────────────────────────
FLASK_PORT=8080
FLASK_DEBUG=False

# ── Live Cache Settings (optional) ───────────────────────────
LIVE_CACHE_TTL_SEC=120
LIVE_SNAPSHOT_TTL_SEC=60
LIVE_HISTORY_RETENTION_HOURS=48
LIVE_HISTORY_MAX_POINTS=720
LIVE_FETCH_WORKERS=6

# ── AQI Email Alerts ─────────────────────────────────────────
# Gmail SMTP example:
#   1. Enable 2-Factor Authentication on your Google account
#   2. Create an App Password at https://myaccount.google.com/apppasswords
#   3. Use smtp.gmail.com:587, your Gmail address, and the App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# `SMTP_USER` can be either the SMTP login email or just a sender display name.
# If it is not an email address, the app will use `SMTP_FROM_EMAIL` for login
# and treat `SMTP_USER` as the friendly sender name.
SMTP_USER=alerts@example.com
SMTP_LOGIN_USER=alerts@example.com
SMTP_SENDER_NAME=AirPulse
SMTP_PASSWORD=your_smtp_password_here
SMTP_FROM_EMAIL=alerts@example.com
SMTP_USE_TLS=true
AQI_ALERT_CHECK_INTERVAL_SEC=600
AQI_ALERT_COOLDOWN_MIN=180

# ── Monitored Cities (optional, comma-separated) ─────────────
# LIVE_MONITOR_CITIES=delhi,mumbai,london,beijing,new york
